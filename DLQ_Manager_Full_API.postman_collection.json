						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"dlqTopicId\": \"{{dlqTopicId}}\",\n    \"messageOffset\": 0,\n    \"messagePartition\": 0,\n    \"initiatedBy\": \"test-user@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/replay/single",
							"host": ["{{baseUrl}}"],
							"path": ["api", "replay", "single"]
						},
						"description": "Replay a single message. Auto-saves the replay job ID."
					}
				},
				{
					"name": "Bulk Replay - 3 Messages",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.replayJob && jsonData.replayJob.id) {",
									"        pm.collectionVariables.set('replayJobId', jsonData.replayJob.id);",
									"    }",

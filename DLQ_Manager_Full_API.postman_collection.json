		{
			"name": "Message Replay",
			"item": [
				{
					"name": "Replay Single Message",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.replayJob && jsonData.replayJob.id) {",
									"        pm.collectionVariables.set('replayJobId', jsonData.replayJob.id);",
									"        console.log('Saved Replay Job ID:', jsonData.replayJob.id);",

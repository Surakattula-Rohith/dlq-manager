					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"dlqTopicId\": \"{{dlqTopicId}}\",\n    \"messages\": [\n        {\"offset\": 0, \"partition\": 0},\n        {\"offset\": 1, \"partition\": 0},\n        {\"offset\": 2, \"partition\": 0}\n    ],\n    \"initiatedBy\": \"test-user@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/replay/bulk",
							"host": ["{{baseUrl}}"],
							"path": ["api", "replay", "bulk"]
						},
						"description": "Bulk replay of 3 messages. Auto-saves the replay job ID."

						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"dlqTopicName\": \"orders-dlq\",\n    \"sourceTopic\": \"orders\",\n    \"detectionType\": \"MANUAL\",\n    \"errorFieldPath\": \"headers.error-message\"\n}"
